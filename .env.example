# ── Required ──────────────────────────────────────────────────────────────────
# Secret token used to authenticate POST /webhook/whatsapp requests.
# Include it in the Authorization header: Bearer <value>
WEBHOOK_SECRET_TOKEN=your_secret_token_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Anthropic API key — if provided, replies are generated by Claude.
# If omitted or the call fails, a built-in mock reply is used instead.
ANTHROPIC_API_KEY=

# Database URL — defaults to a local SQLite file (conversations.db).
# Switch to PostgreSQL by providing a full DSN, e.g.:
#   postgresql://user:password@localhost:5432/whatsapp_agent
DATABASE_URL=sqlite:///./conversations.db
